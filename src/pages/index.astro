---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <section class="hero">
    <div class="container container--narrow hero__content">
      <h1 class="hero__title">Dromerij</h1>
      <p class="hero__subtitle">
        Atelier voor handgemaakt keramiek — waar klei vorm krijgt en dromen
        gebakken worden.
      </p>
      <a href={import.meta.env.BASE_URL + "/gallery"} class="btn">Bekijk het werk</a>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section__title">Welkom</h2>
      <p style="text-align: center; color: var(--color-text-muted); font-size: 1.1rem; max-width: 36rem; margin: 0 auto;">
        Elk stuk wordt met de hand gedraaid, met aandacht voor vorm, textuur en
        functionaliteit. Ontdek de collectie en neem contact op voor een
        atelierbezoek.
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 5rem;
    text-align: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero__title {
    font-size: clamp(3rem, 8vw, 5rem);
    letter-spacing: 0.02em;
  }

  .hero__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 32rem;
  }
</style>
